{
  "name": "xyzzy",
  "version": "0.0.0",
  "description": "A toolkit for building and playing text adventures with local LLMs.",
  "keywords": [
    "text-adventure",
    "interactive-fiction",
    "llm",
    "ollama",
    "cli",
    "ink"
  ],
  "license": "TBD",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "xyzzy": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^0.2.16",
    "ai": "^4.3.19",
    "commander": "^12.1.0",
    "ink": "^5.2.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "yaml": "^2.9.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.31",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.39.5",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.9.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^2.1.9"
  }
}
